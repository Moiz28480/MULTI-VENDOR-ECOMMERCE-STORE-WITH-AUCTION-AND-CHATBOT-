# Vite env vars must start with VITE_

# Appwrite Cloud Function ID for the bid placement function.
# IMPORTANT: This must be the Function *ID* from the Appwrite Console, not the display name.
VITE_PLACE_BID_FUNCTION_ID=

# Optional aliases used by some setups (supported by the UI as fallback)
# VITE_APPWRITE_PLACE_BID_FUNCTION_ID=

# Optional existing envs in this repo
# VITE_API_BASE_URL=
# VITE_ADMIN_BAN_ENDPOINT=
# VITE_ENABLE_PASSWORDLESS_BYPASS=false

# Script-only environment variables (do not expose in frontend)
# APPWRITE_API_KEY=
# APPWRITE_DEFAULT_USER_PASSWORD=
# APPWRITE_DEFAULT_VENDOR_PASSWORD=
# SEED_VENDOR_PASSWORD=
